# 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、値を設定してください
# ※ .env.local は .gitignore に含まれており、Git にコミットされません
# ※ 本番環境では Vercel ダッシュボードから設定してください（Claude Code からは設定しない）

# Anthropic API キー
# https://console.anthropic.com/settings/keys で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob の読み書きトークン
# Vercel ダッシュボード → Storage → Blob → Connect で取得
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# cron-job.org との認証用シークレット
# 任意の強固なランダム文字列を設定（例: openssl rand -hex 32 で生成）
CRON_SECRET=your_cron_secret_here
